# H2: pinned by digest
FROM python:3.12.11-slim@sha256:47ae396f09c1303b8653019811a8498470603d7ffefc29cb07c88f1f8cb3d19f

WORKDIR /app

COPY setup.py /app/
COPY src/ /app/src/
COPY tests/ /app/tests/
COPY packages/ /app/packages/

RUN pip install --no-cache-dir -e ".[test]"
RUN pip install --no-cache-dir pytest pytest-cov psutil

# M1+M2: create non-root user; restrict directory permissions
RUN adduser --disabled-password --gecos "" testuser \
    && mkdir -p /data /app/shares \
    && chown -R testuser:testuser /app /data \
    && chmod 750 /data /app/shares

USER testuser

WORKDIR /app/tests
ENTRYPOINT ["python", "run_tests.py"]
